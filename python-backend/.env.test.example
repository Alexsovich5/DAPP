# Test Environment Configuration
# Soul Before Skin Dating Platform - Test Settings

# Database Configuration
DATABASE_URL=postgresql://postgres:test_password@localhost:5432/dinner_first_test

# Security Configuration
SECRET_KEY=test-secret-key-for-ci-soul-before-skin-dating-platform-very-secure-long-key-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Configuration
CORS_ORIGINS=http://localhost:4200,http://localhost:5001

# Redis Configuration
REDIS_URL=redis://localhost:6379/1

# Application Environment
ENVIRONMENT=testing
DEBUG=true

# Soul Before Skin Specific Configuration
COMPATIBILITY_THRESHOLD=50
REVELATION_CYCLE_DAYS=7
EMOTIONAL_DEPTH_WEIGHT=0.3
PHOTO_REVEAL_CONSENT_REQUIRED=true

# File Upload Configuration (Test)
MAX_UPLOAD_SIZE=5242880  # 5MB for tests
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,image/gif

# Performance Configuration (Test)
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
CACHE_TTL=300

# Analytics Configuration (Test)
ANALYTICS_ENABLED=false
AB_TESTING_ENABLED=true

# Notification Configuration (Test)
PUSH_NOTIFICATIONS_ENABLED=false
EMAIL_NOTIFICATIONS_ENABLED=false

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security Test Configuration
RATE_LIMITING_ENABLED=true
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Test Data Configuration
GENERATE_TEST_DATA=true
TEST_USERS_COUNT=10
TEST_CONNECTIONS_COUNT=20
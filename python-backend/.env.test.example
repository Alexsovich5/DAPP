# Test Environment Configuration
# Copy this to .env.test for local testing

# Database
DATABASE_URL=postgresql://postgres:test_password@localhost:5432/dinner_first_test

# JWT Configuration
SECRET_KEY=test_secret_key_for_jwt_tokens_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Settings
DEBUG=True
ENVIRONMENT=test

# CORS Settings
CORS_ORIGINS=http://localhost:4200,http://localhost:5001

# Test-specific settings
TESTING=True
DISABLE_AUTH=False
REDIS_URL=redis://localhost:6379/1

# Email settings (disabled for tests)
EMAIL_ENABLED=False
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=test@example.com
SMTP_PASSWORD=test_password

# External API settings (mock for tests)
OPENAI_API_KEY=test_openai_key
ANTHROPIC_API_KEY=test_anthropic_key

# Feature flags for testing
SOUL_BEFORE_SKIN_ENABLED=True
PHOTO_REVEAL_ENABLED=True
AI_MATCHING_ENABLED=False

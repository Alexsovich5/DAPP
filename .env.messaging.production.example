# Messaging Service Production Environment Variables
# Copy this file to .env.messaging.production and set actual values
# DO NOT commit the actual .env.messaging.production file to version control

# RabbitMQ Configuration
RABBITMQ_URL=amqp://username:password@rabbitmq.dinner-first-messaging.svc.cluster.local:5672
RABBITMQ_VHOST=/
RABBITMQ_USERNAME=messaging_user
RABBITMQ_PASSWORD=secure_password_here

# Encryption Configuration
MESSAGE_ENCRYPTION_KEY=your_secure_encryption_key_here
MESSAGE_ENCRYPTION_ALGORITHM=AES-256-GCM

# Service Configuration
MESSAGING_SERVICE_PORT=8080
MESSAGING_DB_HOST=messaging-db.dinner-first-messaging.svc.cluster.local
MESSAGING_DB_PORT=5432
MESSAGING_DB_NAME=messaging_db
MESSAGING_DB_USERNAME=messaging_user
MESSAGING_DB_PASSWORD=secure_db_password_here
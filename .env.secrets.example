# Example secrets file - DO NOT commit actual values
# Copy to .env.secrets and fill in actual values

# Database passwords
POSTGRES_PASSWORD=your_secure_postgres_password_here
REDIS_PASSWORD=your_secure_redis_password_here
CLICKHOUSE_PASSWORD=your_secure_clickhouse_password_here

# JWT and encryption keys
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long
MESSAGE_ENCRYPTION_KEY=your_32_character_message_encryption_key
PHOTO_ENCRYPTION_KEY=your_32_character_photo_encryption_key

# External service API keys
EMAIL_API_KEY=your_sendgrid_api_key_here
SMS_API_KEY=your_twilio_api_key_here
CONTENT_MODERATION_API_KEY=your_content_moderation_api_key

# Storage service keys
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# Monitoring passwords
GRAFANA_PASSWORD=your_grafana_password

# Message queue passwords
RABBITMQ_PASSWORD=your_rabbitmq_password

# Push notification keys
PUSH_SERVICE_KEY=your_push_service_key
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key